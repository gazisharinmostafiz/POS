APP_NAME="Tong POS"
APP_VERSION=0.1.0
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
TENANCY_ROOT_DOMAIN=
HTTP_PORT=80
HTTPS_PORT=443

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
ERROR_TRACKING_DSN=

DB_CONNECTION=pgsql
DB_HOST=database
DB_PORT=5432
DB_DATABASE=tong_pos
DB_USERNAME=tong_pos
DB_PASSWORD=tong_pos

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

BACKUP_ENCRYPTION_KEY=
BACKUP_REMOTE_DRIVER=local
BACKUP_REMOTE_ROOT=
BACKUP_REMOTE_ENABLED=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8080
REVERB_SCHEME=https

STRIPE_SECRET=
STRIPE_SUBSCRIPTION_WEBHOOK_SECRET=
STRIPE_API_BASE_URL=https://api.stripe.com
STRIPE_SUBSCRIPTION_GRACE_DAYS=7

VITE_APP_NAME="${APP_NAME}"
VITE_API_BASE_URL="${APP_URL}"
CAPACITOR_SERVER_URL="${APP_URL}"
CAPACITOR_ANDROID_APP_ID=com.poslab.placeholder
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
